rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── 채팅 이미지 ─────────────────────────────────────────────────
    // 경로: chatImages/{matchId}/{imagePath}
    match /chatImages/{matchId}/{imagePath} {

      // 해당 match의 참여자인지 확인하는 함수
      function isMatchParticipant() {
        let matchDoc = firestore.get(/databases/(default)/documents/matches/$(matchId));
        return request.auth.uid in matchDoc.data.users;
      }

      // 인증된 사용자 + match 참여자만 읽기/쓰기 허용
      // 이미지 MIME type만 허용
      allow read: if request.auth != null
                  && isMatchParticipant();

      allow write: if request.auth != null
                   && isMatchParticipant()
                   && request.resource.contentType.matches('image/.*');
    }

    // 그 외 경로는 기본 거부
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
